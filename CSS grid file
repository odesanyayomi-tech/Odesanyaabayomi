@media(max-width: 500px){
    
    body{
    grid-template-areas: 
    "header"
    "section"
    "content"
    "footer";
    grid-template-columns: 1fr;
    grid-template-rows: 100px 600px 1fr 80px ;

    header{
    flex-direction: column;
}

.container{
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(5,1fr);
}

    


}


